APP_NAME=Apex Signal API
DEBUG=true
SECRET_KEY=change-me
DATABASE_URL=sqlite:///./apex.db
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_EXCHANGE=NASDAQ

# ── Data provider ─────────────────────────────────────────────────────────────
# demo    → deterministic fake data, no network calls
# yfinance → real market data from Yahoo Finance (free, no API key needed)
# hybrid  → XBRL (point-in-time fundamentals from SEC EDGAR) + yfinance (prices)
DATA_PROVIDER=hybrid
YFINANCE_HISTORY_DAYS=370

# ── Bulk ingestion ─────────────────────────────────────────────────────────────
# Number of parallel threads for bulk ingest (8 is safe for yfinance rate limits)
INGEST_WORKERS=8
# Seconds between submitting each ticker to the pool (throttle)
INGEST_INTER_DELAY=0.25

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
# Override individual job hours (UTC)
# SCHEDULER_INGEST_HOUR=23
# SCHEDULER_SCORING_HOUR=1
# SCHEDULER_SCANNER_HOUR=1
# SCHEDULER_SCANNER_MINUTE=30
# SCHEDULER_PORTFOLIO_HOUR=2

# ── Scoring weights ────────────────────────────────────────────────────────────
# Defaults below. After running POST /backtest/run, copy the suggested values here.
# Weights are auto-normalised to sum to 1.0 (risk is a separate penalty).
SCORE_WEIGHT_GROWTH=0.30
SCORE_WEIGHT_QUALITY=0.25
SCORE_WEIGHT_VALUATION=0.15
SCORE_WEIGHT_MARKET=0.40
SCORE_WEIGHT_NARRATIVE=0.10
SCORE_WEIGHT_RISK=0.15
# Set to true to use narrative as an entry filter instead of a score component
SCORE_NARRATIVE_AS_FILTER=true

# ── Parallel scoring ───────────────────────────────────────────────────────
# Number of parallel threads for daily scoring.
# 1 = sequential (safe default, fine for <200 tickers)
# 8 = good balance for 1000+ tickers (each thread uses own DB session)
SCORE_WORKERS=8

# ── XBRL disk cache ────────────────────────────────────────────────────────
# Days before re-fetching company facts from SEC EDGAR (default: 7)
# Cache lives in backend/.cache/xbrl/{cik}.json
XBRL_CACHE_TTL_DAYS=7
